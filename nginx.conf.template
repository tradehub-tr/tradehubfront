# ── SEO ortam izolasyonu (FAIL-CLOSED) ─────────────────────────────
# ${FRONTEND_DOMAIN} envsubst ile render anında literal'e döner; map bir
# sabiti eşler. YALNIZ prod (istoc.com) boş header (= header basılmaz) ve
# Allow'lu robots dosyası alır. Env boş/yanlış/eksikse default = noindex +
# Disallow (staging'in yanlışlıkla indexlenmesi yerine prod'un yanlışlıkla
# deindeks olması tercih edilir — merge kapısı: compose-env FAZ A kanıtı).
map "${FRONTEND_DOMAIN}" $robots_tag {
    default     "noindex, nofollow";
    "istoc.com" "";
}
map "${FRONTEND_DOMAIN}" $robots_file {
    default     /robots-noindex.txt;
    "istoc.com" /robots-prod.txt;
}

server {
    listen 80;
    server_name _;
    root /usr/share/nginx/html;

    # www → apex 301 — container savunma katmanı (birincil mekanizma Sunucu B
    # host-nginx vhost'u). Staging'de www.<env> DNS'i yok → koşul hiç tutmaz.
    if ($host = "www.${FRONTEND_DOMAIN}") {
        return 301 https://${FRONTEND_DOMAIN}$request_uri;
    }

    # ── Sıkıştırma — metin tabanlı asset'lerin transfer boyutunu ~%75 düşürür.
    gzip on;
    gzip_vary on;
    gzip_comp_level 6;
    gzip_min_length 1024;
    gzip_proxied any;
    gzip_types
        text/plain
        text/css
        text/javascript
        application/javascript
        application/json
        application/manifest+json
        application/xml
        text/xml
        image/svg+xml;

    # ── SEO: ortam-koşullu X-Robots-Tag (map $robots_tag) ─────────
    # Prod'da değer boş → nginx header'ı HİÇ basmaz; diğer tüm ortamlarda
    # noindex. NOT (add_header miras tuzağı): kendi add_header'ı olan
    # location'lar (/api/, /assets/, resim regex'i) bu header'ı MİRAS ALMAZ —
    # o bloklara ayrıca eklendi. check-nginx-noindex.sh sayım assert'i: 4.
    add_header X-Robots-Tag $robots_tag always;

    # ── Güvenlik header'ları ──────────────────────────────────────
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://${BACKEND_DOMAIN} wss://${BACKEND_DOMAIN}; frame-ancestors 'none';" always;

    # Hayalet path kararı: /markalar kaybetti → kalıcı 301 /ureticiler
    # (nginx map + backend static_pages_registry + FE listesi senkron).
    location = /markalar {
        return 301 /ureticiler;
    }

    # ── robots.txt — ortama göre statik dosya (map $robots_file) ──
    # İki dosya da dist'te (public/robots-*.txt): string-escape/newline tuzağı
    # yok, map yalnız hangi dosyanın servis edileceğini seçer. Prod gövdesine
    # Sitemap satırı BE-MAP canlıya çıkınca eklenir (404 sitemap ilan etme).
    location = /robots.txt {
        try_files $robots_file =404;
    }

    # ── sitemap.xml — backend proxy (BE-MAP canlıya çıkana kadar bilinçli 404)
    location = /sitemap.xml {
        proxy_hide_header X-Robots-Tag;
        proxy_set_header X-Istoc-Storefront "1";
        proxy_pass https://${BACKEND_DOMAIN}/api/method/tradehub_core.api.seo.get_sitemap_index;
        proxy_ssl_server_name on;
        proxy_set_header Host ${BACKEND_DOMAIN};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }
    location ~ ^/sitemap-([a-z0-9-]+)\.xml$ {
        proxy_hide_header X-Robots-Tag;
        proxy_set_header X-Istoc-Storefront "1";
        proxy_pass https://${BACKEND_DOMAIN}/api/method/tradehub_core.api.seo.get_sitemap?name=$1;
        proxy_ssl_server_name on;
        proxy_set_header Host ${BACKEND_DOMAIN};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    # Frappe API proxy
    location /api/ {
        # CORS — whitelist: GitHub Pages, *.istoc.com subdomain'leri, Capacitor WebView (iOS/Android).
        # Regex ile m/app/preview/admin-preview.istoc.com toplu eşleşme.
        set $cors_origin "";
        if ($http_origin = "https://tradehub-tr.github.io") {
            set $cors_origin $http_origin;
        }
        if ($http_origin ~ "^https://(m|app|preview|admin-preview)\.istoc\.com$") {
            set $cors_origin $http_origin;
        }
        # Capacitor native WebView (iOS https scheme + iosScheme: 'https')
        if ($http_origin = "https://localhost") {
            set $cors_origin $http_origin;
        }
        # Capacitor varsayılan scheme (eski versiyonlar veya fallback)
        if ($http_origin = "capacitor://localhost") {
            set $cors_origin $http_origin;
        }
        add_header Access-Control-Allow-Origin $cors_origin always;
        add_header Access-Control-Allow-Credentials "true" always;
        add_header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS, PATCH" always;
        add_header Access-Control-Allow-Headers "Content-Type, X-Frappe-CSRF-Token, Authorization" always;
        # Miras tuzağı: bu blok kendi add_header'larını tanımladığı için
        # server-level X-Robots-Tag buraya inmez — açıkça tekrarlanır.
        add_header X-Robots-Tag $robots_tag always;

        # Preflight OPTIONS
        if ($request_method = OPTIONS) {
            return 204;
        }

        # Backend'den gelen CORS header'larını sil (çift değer olmasın)
        proxy_hide_header Access-Control-Allow-Origin;
        proxy_hide_header Access-Control-Allow-Credentials;
        proxy_hide_header Access-Control-Allow-Methods;
        proxy_hide_header Access-Control-Allow-Headers;
        # Backend'in (noindex_guard) X-Robots-Tag'i edge'e sızmasın — header
        # politikasının tek sahibi bu nginx'tir.
        proxy_hide_header X-Robots-Tag;

        proxy_pass https://${BACKEND_DOMAIN}/api/;
        proxy_cookie_domain ${BACKEND_DOMAIN} ${FRONTEND_DOMAIN};
        proxy_cookie_flags ~ SameSite=None Secure;
        proxy_ssl_server_name on;
        proxy_set_header Host ${BACKEND_DOMAIN};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    # Private files — Frappe permission-checked download (identity docs etc.)
    # ^~ ZORUNLU: aşağıdaki resim-uzantı regex'i (~* \.(png|jpg…)$) bu prefix'i
    # ezmesin diye. ^~ olmadan /private/files/x.jpg backend yerine regex'e düşer.
    location ^~ /private/files/ {
        proxy_hide_header X-Robots-Tag;
        proxy_pass https://${BACKEND_DOMAIN}/private/files/;
        proxy_ssl_server_name on;
        proxy_set_header Host ${BACKEND_DOMAIN};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Public files (product images etc.)
    # ^~ ZORUNLU: resim-uzantı regex'i (~* \.(png|jpg…)$) bu prefix'i ezmesin.
    # ^~ olmadan /files/urun.jpg backend'e gitmez, regex'e düşer → 404.
    location ^~ /files/ {
        proxy_hide_header X-Robots-Tag;
        proxy_pass https://${BACKEND_DOMAIN}/files/;
        proxy_ssl_server_name on;
        proxy_set_header Host ${BACKEND_DOMAIN};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # File upload size limit
    client_max_body_size 50m;

    # Vite build assets — önce lokal dosyaya bak, yoksa Frappe'ye proxy et.
    # Hash'li dosya isimleri (style-M3JxMgvs.css) içeriğe bağlı → içerik
    # değişince isim değişir. Bu yüzden immutable + 1 yıl cache güvenli;
    # "Efficient cache lifetimes" (3MB) denetimini tamamen kapatır.
    # ^~ ZORUNLU: /assets/ içinde .svg/.png/.woff2 gibi uzantılar resim regex'ine
    # düşmesin; bu blok zaten @frappe_assets fallback'i ile backend'e gidiyor.
    location ^~ /assets/ {
        add_header Cache-Control "public, max-age=31536000, immutable";
        add_header X-Robots-Tag $robots_tag always;
        try_files $uri @frappe_assets;
    }
    location @frappe_assets {
        proxy_hide_header X-Robots-Tag;
        proxy_pass https://${BACKEND_DOMAIN};
        proxy_ssl_server_name on;
        proxy_set_header Host ${BACKEND_DOMAIN};
    }

    # Socket.IO WebSocket proxy
    location /socket.io/ {
        proxy_hide_header X-Robots-Tag;
        proxy_pass https://${BACKEND_DOMAIN}/socket.io/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_ssl_server_name on;
        proxy_set_header Host ${BACKEND_DOMAIN};
    }

    # Dinamik SEO URL'leri — bot: backend'den meta injection, user: lokal HTML
    location ~ ^/urun/(.+)$ {
        error_page 418 = @seo_listing;
        if ($is_bot) { return 418; }
        rewrite ^ /pages/product-detail.html break;
    }
    location @seo_listing {
        internal;
        rewrite ^/urun/(.+)$ /api/method/tradehub_core.seo.page_resolver.render_listing?slug=$1 break;
        # Paylaşım önizlemesinde müşteri backend domaini görmesin (canonical/og:url → ${FRONTEND_DOMAIN}).
        proxy_set_header Accept-Encoding "";
        sub_filter "${BACKEND_DOMAIN}" "${FRONTEND_DOMAIN}";
        sub_filter_once off;
        proxy_hide_header X-Robots-Tag;
        proxy_set_header X-Istoc-Storefront "1";
        proxy_pass https://${BACKEND_DOMAIN};
        proxy_ssl_server_name on;
        proxy_set_header Host ${BACKEND_DOMAIN};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    location ~ ^/kategori/(.+)$ {
        error_page 418 = @seo_category;
        if ($is_bot) { return 418; }
        rewrite ^ /pages/categories.html break;
    }
    location @seo_category {
        internal;
        rewrite ^/kategori/(.+)$ /api/method/tradehub_core.seo.page_resolver.render_category?slug=$1 break;
        # Paylaşım önizlemesinde müşteri backend domaini görmesin (canonical/og:url → ${FRONTEND_DOMAIN}).
        proxy_set_header Accept-Encoding "";
        sub_filter "${BACKEND_DOMAIN}" "${FRONTEND_DOMAIN}";
        sub_filter_once off;
        proxy_hide_header X-Robots-Tag;
        proxy_set_header X-Istoc-Storefront "1";
        proxy_pass https://${BACKEND_DOMAIN};
        proxy_ssl_server_name on;
        proxy_set_header Host ${BACKEND_DOMAIN};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    location ~ ^/marka/(.+)$ {
        error_page 418 = @seo_brand;
        if ($is_bot) { return 418; }
        rewrite ^ /pages/brand.html break;
    }
    location @seo_brand {
        internal;
        rewrite ^/marka/(.+)$ /api/method/tradehub_core.seo.page_resolver.render_brand?slug=$1 break;
        # Paylaşım önizlemesinde müşteri backend domaini görmesin (canonical/og:url → ${FRONTEND_DOMAIN}).
        proxy_set_header Accept-Encoding "";
        sub_filter "${BACKEND_DOMAIN}" "${FRONTEND_DOMAIN}";
        sub_filter_once off;
        proxy_hide_header X-Robots-Tag;
        proxy_set_header X-Istoc-Storefront "1";
        proxy_pass https://${BACKEND_DOMAIN};
        proxy_ssl_server_name on;
        proxy_set_header Host ${BACKEND_DOMAIN};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    # Seller shop (mağaza dükkânı) — frontend SPA, SEO proxy değil
    location ~ ^/magaza/([^/]+)/dukkan$ {
        rewrite ^ /pages/seller/seller-shop.html break;
    }

    location ~ ^/magaza/(.+)$ {
        error_page 418 = @seo_seller;
        if ($is_bot) { return 418; }
        rewrite ^ /pages/seller/seller-storefront.html break;
    }
    location @seo_seller {
        internal;
        rewrite ^/magaza/(.+)$ /api/method/tradehub_core.seo.page_resolver.render_seller?slug=$1 break;
        # Paylaşım önizlemesinde müşteri backend domaini görmesin (canonical/og:url → ${FRONTEND_DOMAIN}).
        proxy_set_header Accept-Encoding "";
        sub_filter "${BACKEND_DOMAIN}" "${FRONTEND_DOMAIN}";
        sub_filter_once off;
        proxy_hide_header X-Robots-Tag;
        proxy_set_header X-Istoc-Storefront "1";
        proxy_pass https://${BACKEND_DOMAIN};
        proxy_ssl_server_name on;
        proxy_set_header Host ${BACKEND_DOMAIN};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    # ── Statik sayfa SEO → backend render_static_page (meta injection)
    # $seo_static_page_path map'te eşleşen path'ler buraya yönlendirilir.
    location @seo_static_backend {
        internal;
        rewrite ^ /api/method/tradehub_core.seo.page_resolver.render_static_page?path=$seo_static_page_path break;
        # Paylaşım önizlemesinde müşteri backend domaini görmesin (canonical/og:url → ${FRONTEND_DOMAIN}).
        proxy_set_header Accept-Encoding "";
        sub_filter "${BACKEND_DOMAIN}" "${FRONTEND_DOMAIN}";
        sub_filter_once off;
        proxy_hide_header X-Robots-Tag;
        proxy_set_header X-Istoc-Storefront "1";
        proxy_pass https://${BACKEND_DOMAIN};
        proxy_ssl_server_name on;
        proxy_set_header Host ${BACKEND_DOMAIN};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    # Statik medya (logo, PWA ikonları, görseller, font) — hash'siz ama nadiren
    # değişir. 30 gün cache + revalidation; HTML bu bloğa girmez (uzantı eşleşmesi).
    location ~* \.(?:png|jpg|jpeg|webp|gif|ico|svg|woff2?|ttf)$ {
        add_header Cache-Control "public, max-age=2592000";
        add_header X-Robots-Tag $robots_tag always;
        try_files $uri @frappe_assets;
    }

    # ──────────────────────────────────────────
    # Admin Panel SPA (/panel) — birleşik container'da (örn. PROD/istoc) admin'i
    # aynı container'dan serve eder. Ayrı-container ortamlarda (beta/rc) /panel
    # zaten upstream'de (gateway) ayrı admin'e yönlenir → bu blok erişilmez/zararsız.
    # ^~ ZORUNLU: /panel/assets/*.js|css yukarıdaki resim/asset regex'lerine düşmesin.
    # ──────────────────────────────────────────
    location ^~ /panel {
        alias /usr/share/nginx/html/panel;
        try_files $uri $uri/ /panel/index.html;
    }

    # Frontend statik dosyalar
    # Bot isteklerinde (Googlebot vb.) statik sayfalar backend'e proxy edilir
    # (SEO meta injection). Normal kullanıcılar dist'ten doğrudan sunulur.
    # Dinamik SEO (/urun/, /kategori/, /marka/, /magaza/) yukarıdaki ayrı
    # location blokları ile her zaman backend'e gider — etkilenmez.
    location / {
        error_page 418 = @seo_static_backend;
        if ($is_bot) {
            set $seo_bot_route $seo_static_page_path;
        }
        if ($seo_bot_route != "") {
            return 418;
        }
        try_files $resolved_page $uri/ $uri.html =404;
    }

    error_page 404 /404.html;
}
