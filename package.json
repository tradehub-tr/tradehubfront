{
  "name": "tradehub",
  "private": true,
  "version": "1.1.9-beta.27",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,js}\"",
    "lint:fix": "eslint \"src/**/*.{ts,js}\" --fix && prettier --write \"src/**/*.{ts,js,json,css}\"",
    "format": "prettier --write \"src/**/*.{ts,js,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,css}\"",
    "cap:sync": "npm run build && cap sync",
    "cap:sync:ios": "npm run build && cap sync ios",
    "cap:sync:android": "npm run build && cap sync android",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "cap:run:ios": "npm run build && cap sync ios && cap run ios",
    "cap:run:android": "npm run build && cap sync android && cap run android",
    "assets:generate": "capacitor-assets generate --iconBackgroundColor '#ffffff' --splashBackgroundColor '#ffffff'"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@eslint/js": "^9.15.0",
    "@types/alpinejs": "^3.13.11",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.3.3",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "fast-glob": "^3.3.3",
    "prettier": "^3.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-window": "^7.4.1"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/network": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@tailwindcss/vite": "^4.1.18",
    "alpinejs": "^3.15.8",
    "dompurify": "^3.3.2",
    "echarts": "^6.1.0",
    "flowbite": "^4.0.1",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-static": "^1.14.0",
    "motion": "^12.38.0",
    "swiper": "^12.1.0",
    "tailwindcss": "^4.1.18"
  }
}
