{
  "name": "tradehub",
  "private": true,
  "version": "2.2.1-rc.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,js}\"",
    "check:dup": "node scripts/check-duplicate-exports.mjs",
    "check:nginx": "bash scripts/check-nginx-noindex.sh",
    "check:seo": "bash scripts/check-seo-path-sync.sh && node scripts/verify-seo-meta.mjs",
    "check:dup:update": "node scripts/check-duplicate-exports.mjs --update",
    "lint:fix": "eslint \"src/**/*.{ts,js}\" --fix && prettier --write \"src/**/*.{ts,js,json,css}\"",
    "format": "prettier --write \"src/**/*.{ts,js,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,css}\"",
    "cap:sync": "npm run build && cap sync",
    "cap:sync:ios": "npm run build && cap sync ios",
    "cap:sync:android": "npm run build && cap sync android",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "cap:run:ios": "npm run build && cap sync ios && cap run ios",
    "cap:run:android": "npm run build && cap sync android && cap run android",
    "assets:generate": "capacitor-assets generate --iconBackgroundColor '#ffffff' --splashBackgroundColor '#ffffff'",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@eslint/js": "^9.15.0",
    "@playwright/test": "^1.60.0",
    "@types/alpinejs": "^3.13.11",
    "@types/alpinejs__collapse": "^3.13.4",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.3.3",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "fake-indexeddb": "^6.2.5",
    "fast-glob": "^3.3.3",
    "happy-dom": "^20.10.2",
    "prettier": "^3.4.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8",
    "workbox-window": "^7.4.1"
  },
  "dependencies": {
    "@alpinejs/collapse": "^3.15.12",
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.1",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/network": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/query-core": "^5.101.0",
    "@tanstack/query-persist-client-core": "^5.101.0",
    "alpinejs": "^3.15.8",
    "dompurify": "^3.3.2",
    "echarts": "^6.1.0",
    "flowbite": "^4.0.1",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "idb-keyval": "^6.2.5",
    "lucide-static": "^1.14.0",
    "motion": "^12.38.0",
    "swiper": "^12.1.0",
    "tailwindcss": "^4.1.18"
  }
}
