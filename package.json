    "prettier": "^3.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "alpinejs": "^3.15.8",
    "dompurify": "^3.3.2",
